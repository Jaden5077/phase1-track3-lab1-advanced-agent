# Local Ollama (default in LLMAgentRuntime; ensure `ollama serve` and e.g. `ollama pull qwen2.5-coder`)
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama
# REFLEXION_MODEL=qwen2.5-coder

# Optional: another tag from `ollama list`, e.g. qwen2.5-coder:7b
# REFLEXION_MODEL=qwen2.5-coder:7b
# Note: "qwen 2.5 coder" (with spaces) is auto-normalized to "qwen2.5-coder".

# Gemini API (OpenAI compatibility)
REFLEXION_MODEL=gemini-2.5-flash-lite
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=your_google_ai_studio_api_key

# OpenRouter (OpenAI-compatible endpoint)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional headers for OpenRouter ranking/analytics:
# OPENROUTER_SITE_URL=https://your-site.example
# OPENROUTER_APP_NAME=reflexion-lab
